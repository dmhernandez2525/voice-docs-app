.kube
.gnupg
.netrc
.npmrc
.yarnrc.yml
node_modules
.pnpm-store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
.next
dist
build
coverage
.cache
.turbo
.parcel-cache
.pytest_cache
.mypy_cache
.ruff_cache
.venv
venv
__pycache__
*.py[cod]
*.sqlite
*.sqlite3
*.db
